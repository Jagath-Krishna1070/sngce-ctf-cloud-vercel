<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Register | SNG COLLEGE CTF</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root { --primary: #9d33ff; --bg: #0d0216; }
        body { 
            font-family: 'Segoe UI', sans-serif; 
            background: radial-gradient(circle at center, #2a0a4d 0%, #0d0216 100%); 
            color: white; 
            margin: 0; 
            min-height: 100vh;
        }

        /* Header Sync */
        .navbar { 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            padding: 20px 60px; 
            background: rgba(0,0,0,0.4); 
            border-bottom: 1px solid rgba(157, 51, 255, 0.2); 
        }
        .logo { font-size: 1.5em; font-weight: bold; color: white; letter-spacing: 1px; text-decoration: none; }
        .nav-links a { text-decoration: none; color: white; margin-left: 25px; font-weight: 600; font-size: 0.9em; transition: 0.3s; }
        .nav-links a:hover { color: var(--primary); }

        /* Register Card */
        .reg-container { display: flex; align-items: center; justify-content: center; padding-top: 40px; }
        .register-card { 
            background: rgba(30, 11, 54, 0.7); 
            padding: 40px; 
            border-radius: 20px; 
            border: 1px solid rgba(157, 51, 255, 0.2); 
            width: 450px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.5); 
            text-align: center; 
        }
        .logo-icon { 
            background: var(--primary); 
            width: 60px; 
            height: 60px; 
            border-radius: 15px; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            margin: 0 auto 20px; 
            font-size: 2em; 
            box-shadow: 0 0 20px rgba(157, 51, 255, 0.5); 
        }
        .input-group { text-align: left; margin-bottom: 15px; }
        .input-group label { font-size: 0.9em; opacity: 0.8; display: block; margin-bottom: 5px; }
        input { 
            width: 100%; 
            padding: 12px; 
            background: rgba(0,0,0,0.3); 
            border: 1px solid rgba(255,255,255,0.1); 
            border-radius: 10px; 
            color: white; 
            box-sizing: border-box; 
        }
        button { 
            width: 100%; 
            padding: 15px; 
            background: var(--primary); 
            border: none; 
            border-radius: 10px; 
            color: white; 
            font-weight: bold; 
            cursor: pointer; 
            margin-top: 10px; 
            font-size: 1.1em; 
            transition: 0.3s; 
        }
        button:hover { background: #b15cff; transform: scale(1.02); }
        .footer-text { margin-top: 25px; opacity: 0.6; font-size: 0.85em; }
        .footer-text a { color: var(--primary); text-decoration: none; font-weight: bold; }
    </style>
</head>
<body>
    <nav class="navbar">
        <a href="/" class="logo"><i class="fas fa-shield-alt"></i> SNG COLLEGE CTF</a>
        <div class="nav-links">
            <a href="/login">LOGIN</a>
            <a href="/register" style="border: 1px solid var(--primary); padding: 8px 20px; border-radius: 20px; color: var(--primary) !important;">REGISTER</a>
        </div>
    </nav>

    <div class="reg-container">
        <div class="register-card">
            <div class="logo-icon"><i class="fas fa-user-plus"></i></div>
            <h1 style="margin-bottom: 5px;">Join the Challenge</h1>
            <p style="opacity: 0.6; margin-bottom: 30px;">Create your hacker profile</p>
            
            <form action="/register" method="POST">
                <div class="input-group">
                    <label>Alias / Username</label>
                    <input type="text" name="username" placeholder="Choose a unique alias" required>
                </div>
                <div class="input-group">
                    <label>Email Address</label>
                    <input type="email" name="email" placeholder="yourname@gmail.com" required>
                </div>
                <div class="input-group">
                    <label>Password</label>
                    <input type="password" name="password" placeholder="Create a strong password" required>
                </div>
                <button type="submit">INITIALIZE PROFILE</button>
            </form>
            
            <div class="footer-text">
                Already registered? <a href="/login">Login here</a>
            </div>
        </div>
    </div>
</body>
</html>