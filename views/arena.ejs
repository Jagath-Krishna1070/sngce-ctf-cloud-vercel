<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Arena | SNG COLLEGE CTF</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root { --primary: #9d33ff; --bg: #0d0216; --card-bg: #1e0b36; }
        body { font-family: 'Segoe UI', sans-serif; background: radial-gradient(circle at top right, #2a0a4d 0%, #0d0216 100%); color: #e0e0e0; margin: 0; min-height: 100vh; }
        .navbar { display: flex; justify-content: space-between; align-items: center; padding: 15px 50px; background: rgba(0,0,0,0.3); border-bottom: 1px solid rgba(157, 51, 255, 0.2); }
        .logo { font-size: 1.5em; font-weight: bold; color: white; text-decoration: none; }
        
        .stats-bar { display: flex; justify-content: space-around; max-width: 1000px; margin: 40px auto; background: rgba(30, 11, 54, 0.6); padding: 25px; border-radius: 15px; border: 1px solid rgba(157, 51, 255, 0.1); text-align: center; }
        .stats-item h2 { margin: 0; color: var(--primary); font-size: 2.2em; }
        .stats-item p { margin: 5px 0 0; opacity: 0.6; font-size: 0.8em; text-transform: uppercase; font-weight: bold; }

        .level-tabs { display: flex; justify-content: center; gap: 15px; margin: 30px auto; }
        .tab-btn { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: white; padding: 12px 25px; border-radius: 8px; cursor: pointer; transition: 0.3s; font-weight: bold; }
        .tab-btn.active { background: var(--primary); box-shadow: 0 0 15px rgba(157, 51, 255, 0.5); border-color: var(--primary); }
        .tab-btn.locked { opacity: 0.3; cursor: not-allowed; }

        .challenge-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 25px; max-width: 1200px; margin: auto; padding: 20px 20px 60px; }
        .challenge-card { background: var(--card-bg); border-radius: 12px; padding: 25px; border: 1px solid rgba(157, 51, 255, 0.1); cursor: pointer; position: relative; transition: 0.3s; }
        .challenge-card:hover { border-color: var(--primary); transform: translateY(-5px); }
        .tag { background: rgba(157, 51, 255, 0.2); color: #c480ff; padding: 4px 12px; border-radius: 20px; font-size: 0.75em; margin-bottom: 15px; display: inline-block; font-weight: 600;}
        .solved-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); border-radius: 12px; display: flex; align-items: center; justify-content: center; color: #4ade80; font-weight: bold; font-size: 1.2em; }
        
        .timer-box { font-size: 1.2em; color: #ff4d4d; border: 1px solid #ff4d4d; padding: 5px 15px; border-radius: 6px; font-family: monospace; font-weight: bold; }
        .dashboard-btn { background: #58a6ff; color: #0d0216; padding: 8px 15px; border-radius: 6px; border: none; cursor: pointer; font-weight: bold; }

        .modal { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.85); z-index:1000; }
        .modal-content { position:absolute; top:50%; left:50%; transform:translate(-50%, -50%); background:#1e0b36; width:450px; padding:35px; border-radius: 20px; border: 1px solid var(--primary); max-height: 80vh; overflow-y: auto; }
        
        /* Scoreboard Specifics */
        .score-row { display: flex; justify-content: space-between; padding: 15px; border-bottom: 1px solid rgba(255,255,255,0.05); }
        .score-row:first-child { font-weight: bold; color: var(--primary); font-size: 1.2em; border-bottom: 2px solid var(--primary); }
    </style>
</head>
<body>
    <nav class="navbar">
        <a href="/" class="logo"><i class="fas fa-shield-alt"></i> SNG COLLEGE CTF</a>
        <div style="display: flex; align-items: center; gap: 20px;">
            <% if (scoreboardVisible) { %>
                <button class="dashboard-btn" onclick="openScoreboard()"><i class="fas fa-trophy"></i> Global Dashboard</button>
            <% } %>
            <div id="timer-display" class="timer-box">00:00</div>
            <a href="/logout" style="color: #ff4d4d; text-decoration: none; font-weight: bold;"><i class="fas fa-power-off"></i> Logout</a>
        </div>
    </nav>

    <% if (!compStarted) { %>
        <div style="text-align: center; margin-top: 150px;">
            <i class="fas fa-lock" style="font-size: 4em; color: var(--primary);"></i>
            <h2>SYSTEM STANDBY</h2>
            <p>Waiting for admin signal...</p>
        </div>
    <% } else { %>
        
        <div style="text-align: center; margin-top: 40px;">
            <h1 style="margin: 0; font-size: 2.5em;">CTF Challenges</h1>
            <p style="opacity: 0.6;">Choose a level and start solving challenges</p>
        </div>

        <div class="level-tabs">
            <button class="tab-btn" id="tab-easy" onclick="switchLevel('easy')">Level 1 (Easy)</button>
            <button class="tab-btn <%= easySolved >= 2 ? '' : 'locked' %>" id="tab-intermediate" onclick="handleLevelClick('intermediate', <%= easySolved %>)">Level 2 (Medium)</button>
            <button class="tab-btn <%= interSolved >= 2 ? '' : 'locked' %>" id="tab-hard" onclick="handleLevelClick('hard', <%= interSolved %>)">Level 3 (Hard)</button>
        </div>

        <div class="stats-bar">
            <div class="stats-item"><h2 id="total-solved"><%= solved.length %></h2><p>Challenges Solved</p></div>
            <div class="stats-item"><h2><%= score.total_points %></h2><p>Total Points</p></div>
            <div class="stats-item"><h2 id="level-progress">0/0</h2><p id="progress-label">Level Progress</p></div>
        </div>

        <div class="challenge-grid" id="challenge-container"></div>
    <% } %>

    <div id="q-modal" class="modal">
        <div class="modal-content">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <span id="modal-tag" class="tag">Topic</span>
                    <h2 id="modal-title" style="margin: 5px 0;">Challenge</h2>
                </div>
                <button onclick="closeModal()" style="background: none; border: none; color: white; font-size: 1.5em; cursor: pointer; opacity: 0.7;">&times;</button>
            </div>
            
            <p id="modal-desc" style="opacity: 0.8; line-height: 1.5;"></p>
            <div id="modal-file" style="margin-bottom: 20px;"></div>
            
            <input type="text" id="flag-input" placeholder="CTF{enter_flag_here}" style="width:100%; padding:15px; background:rgba(0,0,0,0.3); border:1px solid #30363d; color:white; border-radius:8px; box-sizing: border-box;">
            
            <button onclick="submitFlag()" style="width:100%; background:var(--primary); color:white; padding:15px; border:none; border-radius:8px; margin-top:15px; font-weight:bold; cursor:pointer; transition: 0.3s;">SUBMIT FLAG</button>
            <button onclick="closeModal()" style="width:100%; background:rgba(255,255,255,0.05); color:white; padding:15px; border:1px solid rgba(255,255,255,0.1); border-radius:8px; margin-top:10px; font-weight:bold; cursor:pointer; transition: 0.3s;">CLOSE TERMINAL</button>
        </div>
    </div>

    <div id="score-modal" class="modal">
        <div class="modal-content" style="width: 500px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h2 style="margin:0;"><i class="fas fa-trophy" style="color: gold;"></i> Global Dashboard</h2>
                <button onclick="closeScoreboard()" style="background: none; border: none; color: white; font-size: 1.5em; cursor: pointer; opacity: 0.7;">&times;</button>
            </div>
            <div class="score-row"><span>Rank & Hacker</span><span>Points</span></div>
            <% if (scoreboard.length > 0) { %>
                <% scoreboard.forEach((s, index) => { %>
                    <div class="score-row">
                        <span><strong>#<%= index + 1 %></strong> &nbsp; <%= s.username %></span>
                        <span style="color: var(--primary); font-weight: bold;"><%= s.total_points %> pts</span>
                    </div>
                <% }) %>
            <% } else { %>
                <div style="text-align: center; padding: 20px; opacity: 0.5;">No active scores yet.</div>
            <% } %>
            <button onclick="closeScoreboard()" style="width:100%; background:rgba(255,255,255,0.05); color:white; padding:15px; border:1px solid rgba(255,255,255,0.1); border-radius:8px; margin-top:20px; font-weight:bold; cursor:pointer;">CLOSE DASHBOARD</button>
        </div>
    </div>

    <script>
        let questions = <%- JSON.stringify(questions) %>;
        let solved = <%- JSON.stringify(solved) %>;
        let starts = <%- JSON.stringify(starts) %>;
        let activeQId = null;
        let interval;
        let initialStatus = <%= compStarted %>;
        let initialScoreboardStatus = <%= scoreboardVisible %>;
        let currentQuestionCount = <%= questions.length %>;

        setInterval(() => {
            fetch('/api/competition-status').then(r => r.json()).then(data => {
                if (data.compStarted != initialStatus || data.questionCount !== currentQuestionCount || data.scoreboardVisible !== initialScoreboardStatus) {
                    location.reload(); 
                }
            });
        }, 3000);

        function openScoreboard() { document.getElementById('score-modal').style.display = 'block'; }
        function closeScoreboard() { document.getElementById('score-modal').style.display = 'none'; }

        function handleLevelClick(level, previousLevelSolvedCount) {
            if (previousLevelSolvedCount >= 2) switchLevel(level);
            else alert("LOCKED: Solve at least 2 challenges in the previous tier first!");
        }

        // FIXED: SessionStorage remembers which tab you were on
        function switchLevel(level) {
            sessionStorage.setItem('activeCTFTab', level);
            let currentLevel = level;
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            const activeBtn = document.getElementById('tab-' + level);
            if (activeBtn) activeBtn.classList.add('active');

            fetch('/start-level', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({level}) })
            .then(res => res.json()).then(data => {
                if(data.firstTime) alert("SYSTEM NOTICE: The timer for " + level.toUpperCase() + " has begun!");
                let existing = starts.find(s => s.level === level);
                if(!existing) starts.push({level: level, start_time: data.start_time});
                
                renderChallenges(level);
                startClock(level);
            });
        }

        function renderChallenges(currentLevel) {
            const container = document.getElementById('challenge-container');
            const filtered = questions.filter(q => q.level === currentLevel);
            const levelSolved = filtered.filter(q => solved.includes(q.id)).length;
            
            document.getElementById('level-progress').innerText = `${levelSolved}/${filtered.length}`;
            document.getElementById('progress-label').innerText = `${currentLevel.toUpperCase()} PROGRESS`;

            container.innerHTML = filtered.map(q => `
                <div class="challenge-card" onclick="openModal(${q.id})">
                    <span class="tag"><i class="fas fa-flag"></i> ${q.topic || 'General'}</span>
                    <h3>${q.question_text.split('.')[0]}</h3>
                    <p style="opacity: 0.5; font-size: 0.85em;">Click to view target intelligence...</p>
                    <div style="position: absolute; bottom: 25px; right: 25px; color: var(--primary); font-weight: bold;">${q.base_points} pts</div>
                    ${solved.includes(q.id) ? '<div class="solved-overlay"><i class="fas fa-check-circle"></i> &nbsp; SOLVED</div>' : ''}
                </div>
            `).join('');
            
            if(currentLevel === 'easy' && levelSolved >= 2 && !sessionStorage.getItem('notifiedMedium')) {
                alert("MEDIUM Tier Unlocked! You can now proceed to Level 2.");
                sessionStorage.setItem('notifiedMedium', 'true');
            }
            if(currentLevel === 'intermediate' && levelSolved >= 2 && !sessionStorage.getItem('notifiedHard')) {
                alert("HARD Tier Unlocked! You can now proceed to Level 3.");
                sessionStorage.setItem('notifiedHard', 'true');
            }
        }

        function openModal(id) {
            const q = questions.find(x => x.id === id);
            activeQId = id;
            document.getElementById('modal-title').innerText = q.question_text.split('.')[0];
            document.getElementById('modal-desc').innerText = q.question_text;
            document.getElementById('modal-tag').innerText = q.topic || 'Intel';
            document.getElementById('modal-file').innerHTML = q.file_url ? `<a href="${q.file_url}" download target="_blank" style="color:var(--primary); text-decoration:none; font-weight: bold;"><i class="fas fa-file-download"></i> Open / Download Attached File</a>` : '';
            
            document.getElementById('flag-input').value = ''; 
            document.getElementById('q-modal').style.display = 'block';
        }

        function submitFlag() {
            const flag = document.getElementById('flag-input').value;
            fetch('/check-flag', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({questionId: activeQId, flag}) })
            .then(r => r.json()).then(data => {
                if(data.correct) { 
                    alert("FLAG ACCEPTED! Points Awarded."); 
                    location.reload(); 
                } else alert("INVALID FLAG.");
            });
        }

        function closeModal() { 
            document.getElementById('q-modal').style.display = 'none'; 
            document.getElementById('flag-input').value = ''; 
        }

        function startClock(level) {
            clearInterval(interval);
            const sData = starts.find(x => x.level === level);
            if (!sData) return;
            
            let start = new Date(sData.start_time).getTime();
            let duration = (level === 'easy' ? 45 : (level === 'intermediate' ? 60 : 60)) * 60000;
            
            interval = setInterval(() => {
                let dist = (start + duration) - Date.now();
                if (dist < 0) { document.getElementById('timer-display').innerText = "EXPIRED"; return; }
                let m = Math.floor(dist / 60000);
                let s = Math.floor((dist % 60000) / 1000);
                document.getElementById('timer-display').innerText = `${m}:${s < 10 ? '0' : ''}${s}`;
            }, 1000);
        }

        // FIXED: Re-opens the exact tab the user was on
        window.onload = () => { 
            if(initialStatus) {
                let savedTab = sessionStorage.getItem('activeCTFTab') || 'easy';
                switchLevel(savedTab);
            }
        };
    </script>
</body>
</html>